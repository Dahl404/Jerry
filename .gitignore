# Jerry - Git Ignore

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Workspace - keep structure, ignore contents
jerry_workspace/**/*
!jerry_workspace/.gitkeep
!jerry_workspace/diary/.gitkeep
!jerry_workspace/summaries/.gitkeep
!jerry_workspace/persona/.gitkeep
!jerry_workspace/logs/.gitkeep
!jerry_workspace/scratchpad/.gitkeep

# Application logs
logs/
*.log
!logs/.gitkeep

# Session state
.state/
*.state

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Test coverage
htmlcov/
.coverage
.coverage.*
coverage.xml

# Documentation builds
docs/_build/

# Distribution
*.tar.gz
*.zip

# Model files (too large for git)
*.gguf
