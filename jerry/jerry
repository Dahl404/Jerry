#!/data/data/com.termux/files/usr/bin/bash
# Jerry Launcher Script
# Automatically starts tmux and runs Jerry inside it

SCRIPT_DIR="/data/data/com.termux/files/home/projects/jerry"
SESSION_NAME="jerry"
LOG_FILE="$SCRIPT_DIR/jerry_error.log"

cd "$SCRIPT_DIR"

echo "🚀 Starting Jerry..."

# Function to run Jerry and capture errors
run_jerry() {
    # Set proper terminal type for curses
    export TERM=xterm-256color
    
    # Check if stdin is a terminal
    if [ ! -t 0 ]; then
        echo "❌ Error: Not running in an interactive terminal"
        echo ""
        echo "You need to run Jerry in a real terminal session."
        echo ""
        echo "Try this:"
        echo "  1. Open Termux app directly"
        echo "  2. Run: tmux"
        echo "  3. Then run: ./jerry"
        exit 1
    fi
    
    python3 jerry_core/main.py 2>&1 | tee -a "$LOG_FILE"
    EXIT_CODE=$?
    if [ $EXIT_CODE -ne 0 ]; then
        echo ""
        echo "❌ Jerry exited with code: $EXIT_CODE"
        echo "📄 Check error log: $LOG_FILE"
    fi
    return $EXIT_CODE
}

# Check if already in tmux
if [ -n "$TMUX" ]; then
    echo "✓ Already in tmux, running Jerry..."
    run_jerry
else
    # Check if tmux works
    if ! tmux info >/dev/null 2>&1; then
        echo "⚠️  tmux server not running. Starting tmux..."
    fi
    
    # Check if session exists
    if tmux has-session -t $SESSION_NAME 2>/dev/null; then
        echo "✓ Attaching to existing session: $SESSION_NAME"
        tmux attach -t $SESSION_NAME
    else
        echo "✓ Creating new tmux session: $SESSION_NAME"
        # Create new session and attach to it
        tmux new -s $SESSION_NAME
    fi
fi
