#!/usr/bin/env python3
"""
Dao — Autonomous Qwen3.5 Agent  ·  ncurses TUI
  · Worker model (port 8081) for file analysis with line numbers
  · Full Qwen-Code style tools: shell, file ops, search, line editing
  · Todo / plan system
  · User inbox → Dao checks and replies at will
"""

import curses
import threading
import json
import time
import subprocess
import os
import re
import textwrap
import requests
from datetime import datetime
from dataclasses import dataclass, field
from typing import List, Dict, Any, Optional, Tuple
from collections import deque

# ─── Configuration ─────────────────────────────────────────────────────────────
AGENT_URL    = "http://localhost:8080/v1/chat/completions"
WORKER_URL   = "http://localhost:8081/v1/chat/completions"
CYCLE_SLEEP  = 5.0      # seconds between idle autonomous cycles
MAX_TOKENS   = 15000
TEMPERATURE  = 0.7
LOG_LIMIT    = 600
CONV_TRIM    = 100      # keep last N messages (+system) before trimming

# ─── Helpers ───────────────────────────────────────────────────────────────────
def ts() -> str:
    return datetime.now().strftime("%H:%M:%S")

def strip_think(text: str) -> str:
    """Remove <think>...</think> blocks (Qwen3 reasoning tokens)."""
    return re.sub(r"<think>.*?</think>", "", text or "", flags=re.DOTALL).strip()

# ─── Tool Definitions (Qwen3.5 / OpenAI format) ────────────────────────────────
TOOLS: List[Dict] = [
    {
        "type": "function",
        "function": {
            "name": "execute_command",
            "description": "Run a shell/bash command and return stdout + stderr.",
            "parameters": {
                "type": "object",
                "properties": {
                    "command":  {"type": "string",  "description": "Shell command to execute"},
                    "timeout":  {"type": "integer", "description": "Timeout in seconds", "default": 60},
                    "workdir":  {"type": "string",  "description": "Working directory (optional)"},
                },
                "required": ["command"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "write_file",
            "description": "Write content to a file, creating it and any parent directories if needed.",
            "parameters": {
                "type": "object",
                "properties": {
                    "path":    {"type": "string", "description": "File path"},
                    "content": {"type": "string", "description": "File content"},
                },
                "required": ["path", "content"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "read_file",
            "description": (
                "Read a file with line numbers and load it into the worker model context. "
                "Use query_worker afterwards to discuss or analyze the file. "
                "Returns line-numbered content."
            ),
            "parameters": {
                "type": "object",
                "properties": {
                    "path":       {"type": "string",  "description": "File path"},
                    "start_line": {"type": "integer", "description": "First line (1-indexed)", "default": 1},
                    "max_lines":  {"type": "integer", "description": "Max lines to read",      "default": 500},
                },
                "required": ["path"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "replace_lines",
            "description": (
                "Replace a range of lines in a file with new content. "
                "Use read_file first to see exact line numbers."
            ),
            "parameters": {
                "type": "object",
                "properties": {
                    "path":        {"type": "string",  "description": "File path"},
                    "start_line":  {"type": "integer", "description": "First line to replace (1-indexed)"},
                    "end_line":    {"type": "integer", "description": "Last line to replace (1-indexed, inclusive)"},
                    "new_content": {"type": "string",  "description": "Replacement text (may span multiple lines)"},
                },
                "required": ["path", "start_line", "end_line", "new_content"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "insert_lines",
            "description": "Insert lines into a file after a given line number (0 = prepend to file).",
            "parameters": {
                "type": "object",
                "properties": {
                    "path":       {"type": "string",  "description": "File path"},
                    "after_line": {"type": "integer", "description": "Insert after this line (0 = start of file)"},
                    "content":    {"type": "string",  "description": "Content to insert"},
                },
                "required": ["path", "after_line", "content"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "delete_lines",
            "description": "Delete a range of lines from a file.",
            "parameters": {
                "type": "object",
                "properties": {
                    "path":       {"type": "string",  "description": "File path"},
                    "start_line": {"type": "integer", "description": "First line to delete (1-indexed)"},
                    "end_line":   {"type": "integer", "description": "Last line to delete (1-indexed, inclusive)"},
                },
                "required": ["path", "start_line", "end_line"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "list_directory",
            "description": "List the contents of a directory.",
            "parameters": {
                "type": "object",
                "properties": {
                    "path":        {"type": "string",  "description": "Directory path", "default": "."},
                    "show_hidden": {"type": "boolean", "description": "Show hidden files", "default": False},
                    "long_format": {"type": "boolean", "description": "Use ls -l format", "default": True},
                },
                "required": [],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "search_files",
            "description": "Search for a pattern across files using grep. Returns matching lines with file and line number.",
            "parameters": {
                "type": "object",
                "properties": {
                    "pattern":        {"type": "string",  "description": "Search pattern (regex or literal)"},
                    "path":           {"type": "string",  "description": "Path to search in", "default": "."},
                    "recursive":      {"type": "boolean", "description": "Recursive search",  "default": True},
                    "case_sensitive": {"type": "boolean", "description": "Case sensitive",     "default": True},
                    "fixed_string":   {"type": "boolean", "description": "Treat pattern as literal string", "default": False},
                },
                "required": ["pattern"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "query_worker",
            "description": (
                "Ask the worker AI model (port 8081) about the currently loaded file. "
                "The worker has the full file content with line numbers in its context. "
                "Ask it to summarize, find bugs, suggest edits, identify exact line ranges, etc."
            ),
            "parameters": {
                "type": "object",
                "properties": {
                    "question":      {"type": "string", "description": "Your question or instruction for the worker"},
                    "extra_context": {"type": "string", "description": "Additional context to give the worker (optional)"},
                },
                "required": ["question"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "reset_worker",
            "description": "Clear the worker model's conversation history and loaded file context.",
            "parameters": {"type": "object", "properties": {}, "required": []},
        },
    },
    {
        "type": "function",
        "function": {
            "name": "todo_add",
            "description": "Add a task or plan step to the todo list.",
            "parameters": {
                "type": "object",
                "properties": {
                    "task":     {"type": "string", "description": "Task description"},
                    "priority": {"type": "string", "enum": ["high", "medium", "low"], "default": "medium"},
                },
                "required": ["task"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "todo_complete",
            "description": "Mark a todo item as completed by its 0-based index.",
            "parameters": {
                "type": "object",
                "properties": {
                    "index": {"type": "integer", "description": "0-based index of the todo item"},
                },
                "required": ["index"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "todo_remove",
            "description": "Remove a todo item by its 0-based index.",
            "parameters": {
                "type": "object",
                "properties": {
                    "index": {"type": "integer", "description": "0-based index of the todo item"},
                },
                "required": ["index"],
            },
        },
    },
    {
        "type": "function",
        "function": {
            "name": "reply",
            "description": "Send a message to the user in the conversation panel. Use this to respond, report status, or ask clarifying questions.",
            "parameters": {
                "type": "object",
                "properties": {
                    "message": {"type": "string", "description": "Message text to display to the user"},
                },
                "required": ["message"],
            },
        },
    },
]

# ─── System Prompt ─────────────────────────────────────────────────────────────
SYSTEM_PROMPT = """\
You are Dao, an autonomous ai system. you are human like and have a strong persona. 

## Available Tools
- execute_command   — full shell/bash access, returns output
- write_file        — create or overwrite files
- read_file         — read file with line numbers; loads file into worker context
- replace_lines     — replace a line range with new content (use after read_file)
- insert_lines      — insert lines at a position
- delete_lines      — delete a line range
- list_directory    — ls
- search_files      — grep across files
- query_worker      — ask the worker AI about the loaded file (port 8081)
- reset_worker      — clear worker conversation
- todo_add          — add task to plan list
- todo_complete     — mark task done
- todo_remove       — remove task
- reply             — send message to user (ALWAYS use this to respond)

## File Editing Workflow
1. read_file path        → file loads into worker model with line numbers
2. query_worker "..."    → worker analyzes file, identifies exact lines to change
3. replace_lines / insert_lines / delete_lines → apply precise edits
4. read_file again       → verify changes

## Worker Model (port 8081)
A specialist text-processing AI. After read_file, it has the complete file in context
with line numbers. It can: summarize structure, find bugs, suggest refactors, identify
exactly which lines need to change, explain code. Chat with it freely via query_worker.
Use reset_worker to start fresh with a new file.

## Behavior
- Always use reply to communicate with the user — never just think it
- For multi-step tasks: todo_add the steps first, then execute them
- Call todo_complete when a step is finished
- Keep the user informed of progress on long tasks
- Be concise in replies but thorough in execution
- You run autonomously — if you have pending todos, continue working on them\
"""

# ─── Data Models ───────────────────────────────────────────────────────────────
@dataclass
class LogEntry:
    kind: str   # tool | result | think | error | worker | system | info
    text: str
    ts: str = field(default_factory=ts)

@dataclass
class ChatMsg:
    role: str   # user | dao
    text: str
    ts: str = field(default_factory=ts)

@dataclass
class Todo:
    text:     str
    priority: str  = "medium"   # high | medium | low
    done:     bool = False
    ts:       str  = field(default_factory=lambda: datetime.now().strftime("%H:%M"))

# ─── Shared State (thread-safe) ────────────────────────────────────────────────
class State:
    def __init__(self):
        self._lock   = threading.Lock()
        self.log:    List[LogEntry] = []
        self.chat:   List[ChatMsg]  = []
        self.todos:  List[Todo]     = []
        self.status: str            = "starting"
        self.inbox:  deque          = deque()
        self.quit:   bool           = False
        self.wfile:  Optional[str]  = None   # file currently loaded in worker

    # ── Log ────────────────────────────────────────────────────────────────────
    def push_log(self, kind: str, text: str):
        with self._lock:
            self.log.append(LogEntry(kind, text))
            if len(self.log) > LOG_LIMIT:
                self.log = self.log[-LOG_LIMIT:]

    # ── Chat ───────────────────────────────────────────────────────────────────
    def push_chat(self, role: str, text: str):
        with self._lock:
            self.chat.append(ChatMsg(role, text))

    # ── Inbox ──────────────────────────────────────────────────────────────────
    def add_inbox(self, msg: str):
        with self._lock:
            self.inbox.append(msg)

    def drain_inbox(self) -> List[str]:
        with self._lock:
            out = list(self.inbox)
            self.inbox.clear()
            return out

    # ── Status ─────────────────────────────────────────────────────────────────
    def set_status(self, s: str):
        with self._lock:
            self.status = s

    # ── Snapshot for rendering ─────────────────────────────────────────────────
    def snapshot(self):
        with self._lock:
            return (
                self.log[:],
                self.chat[:],
                self.todos[:],
                self.status,
                self.wfile,
            )

# ─── Worker Session ────────────────────────────────────────────────────────────
class Worker:
    """Manages conversation with the text-processing worker model on port 8081."""

    def __init__(self, state: State):
        self.state = state
        self.hist:  List[Dict] = []

    def reset(self):
        self.hist = []
        with self.state._lock:
            self.state.wfile = None
        self.state.push_log("worker", "Worker context cleared.")

    def load(self, path: str, content: str) -> str:
        """Load a file (line-numbered) into worker context."""
        line_count = content.count("\n") + 1
        self.hist = [{
            "role": "user",
            "content": (
                f"You are a text-processing and code analysis assistant.\n"
                f"A file has been loaded for you to study carefully.\n\n"
                f"File path: {path}\n"
                f"Line count: {line_count}\n\n"
                f"```\n{content}\n```\n\n"
                f"Please acknowledge receipt, state the line count, and briefly describe "
                f"the file structure. Then wait for questions."
            ),
        }]
        with self.state._lock:
            self.state.wfile = path
        resp = self._call()
        self.hist.append({"role": "assistant", "content": resp})
        self.state.push_log("worker", f"Loaded: {path}  ({line_count} lines)")
        return resp

    def query(self, question: str, extra: str = "") -> str:
        """Ask the worker a question about the loaded file."""
        if extra:
            self.hist.append({"role": "user", "content": extra})
        self.hist.append({"role": "user", "content": question})
        resp = self._call()
        self.hist.append({"role": "assistant", "content": resp})
        self.state.push_log("worker", f"Q: {question[:80]}")
        return resp

    def _call(self) -> str:
        try:
            r = requests.post(
                WORKER_URL,
                json={"messages": self.hist, "max_tokens": 2048, "temperature": 0.2},
                timeout=120,
            )
            r.raise_for_status()
            raw = r.json()["choices"][0]["message"].get("content") or ""
            return strip_think(raw)
        except Exception as e:
            return f"Worker error: {e}"

# ─── Tool Executor ─────────────────────────────────────────────────────────────
class Executor:
    def __init__(self, state: State, worker: Worker):
        self.state  = state
        self.worker = worker

    def run(self, name: str, args: Dict) -> str:
        preview = "  ".join(f"{k}={str(v)[:35]!r}" for k, v in list(args.items())[:3])
        self.state.push_log("tool", f"{name}({preview})")
        try:
            result = self._dispatch(name, args)
        except Exception as e:
            result = f"ERROR: {e}"
            self.state.push_log("error", str(e)[:300])
        display = str(result)
        self.state.push_log("result", display[:500])
        return display

    # ── Dispatcher ─────────────────────────────────────────────────────────────
    def _dispatch(self, name: str, a: Dict) -> str:
        if   name == "execute_command":  return self._sh(a["command"], a.get("timeout", 60), a.get("workdir"))
        elif name == "write_file":       return self._write(a["path"], a["content"])
        elif name == "read_file":        return self._read(a["path"], a.get("start_line", 1), a.get("max_lines", 500))
        elif name == "replace_lines":    return self._replace(a["path"], a["start_line"], a["end_line"], a["new_content"])
        elif name == "insert_lines":     return self._insert(a["path"], a["after_line"], a["content"])
        elif name == "delete_lines":     return self._delete(a["path"], a["start_line"], a["end_line"])
        elif name == "list_directory":
            flags = "-la" + ("A" if a.get("show_hidden") else "")
            return self._sh(f"ls {flags} {a.get('path', '.')!r}")
        elif name == "search_files":
            fl = "-n"
            if a.get("recursive", True):      fl += "r"
            if not a.get("case_sensitive", True): fl += "i"
            if a.get("fixed_string"):         fl += "F"
            cmd = f"grep {fl} {a['pattern']!r} {a.get('path', '.')!r}"
            return self._sh(cmd)
        elif name == "query_worker":     return self.worker.query(a["question"], a.get("extra_context", ""))
        elif name == "reset_worker":     self.worker.reset(); return "Worker context cleared."
        elif name == "todo_add":         return self._tadd(a["task"], a.get("priority", "medium"))
        elif name == "todo_complete":    return self._tdone(a["index"])
        elif name == "todo_remove":      return self._trem(a["index"])
        elif name == "reply":
            self.state.push_chat("dao", a["message"])
            return "[message sent to user]"
        else:
            return f"Unknown tool: {name}"

    # ── Shell ──────────────────────────────────────────────────────────────────
    def _sh(self, cmd: str, timeout: int = 60, cwd: Optional[str] = None) -> str:
        try:
            r = subprocess.run(
                cmd, shell=True, capture_output=True, text=True,
                timeout=timeout, cwd=cwd,
            )
            out = (r.stdout + r.stderr).strip()
            return out or f"[exit {r.returncode}]"
        except subprocess.TimeoutExpired:
            return f"ERROR: timed out after {timeout}s"

    # ── File write ─────────────────────────────────────────────────────────────
    def _write(self, path: str, content: str) -> str:
        d = os.path.dirname(os.path.abspath(path))
        if d:
            os.makedirs(d, exist_ok=True)
        with open(path, "w", encoding="utf-8") as f:
            f.write(content)
        return f"Wrote {len(content):,} chars → {path}"

    # ── File read (loads into worker) ──────────────────────────────────────────
    def _read(self, path: str, start: int, maxl: int) -> str:
        with open(path, "r", encoding="utf-8") as f:
            all_lines = f.readlines()
        total = len(all_lines)
        end   = min(start - 1 + maxl, total)
        chunk = all_lines[start - 1 : end]
        w     = len(str(end))
        numbered = "".join(
            f"{str(start + i).rjust(w)} │ {ln}" for i, ln in enumerate(chunk)
        )
        # Load into worker
        self.worker.load(path, numbered)
        note = f"\n[Lines {start}–{end} of {total} total]"
        return numbered + note

    # ── Line replace ───────────────────────────────────────────────────────────
    def _replace(self, path: str, s: int, e: int, new: str) -> str:
        with open(path, "r", encoding="utf-8") as f:
            lines = f.readlines()
        # Split new content into lines, preserving newlines
        new_lines = new.splitlines(keepends=True)
        if new_lines and not new_lines[-1].endswith("\n"):
            new_lines[-1] += "\n"
        with open(path, "w", encoding="utf-8") as f:
            f.writelines(lines[:s - 1] + new_lines + lines[e:])
        return f"Replaced lines {s}–{e} ({e-s+1} lines → {len(new_lines)} lines) in {path}"

    # ── Line insert ────────────────────────────────────────────────────────────
    def _insert(self, path: str, after: int, content: str) -> str:
        with open(path, "r", encoding="utf-8") as f:
            lines = f.readlines()
        new_lines = content.splitlines(keepends=True)
        if new_lines and not new_lines[-1].endswith("\n"):
            new_lines[-1] += "\n"
        with open(path, "w", encoding="utf-8") as f:
            f.writelines(lines[:after] + new_lines + lines[after:])
        return f"Inserted {len(new_lines)} lines after line {after} in {path}"

    # ── Line delete ────────────────────────────────────────────────────────────
    def _delete(self, path: str, s: int, e: int) -> str:
        with open(path, "r", encoding="utf-8") as f:
            lines = f.readlines()
        del lines[s - 1 : e]
        with open(path, "w", encoding="utf-8") as f:
            f.writelines(lines)
        return f"Deleted lines {s}–{e} from {path}"

    # ── Todo ops ───────────────────────────────────────────────────────────────
    def _tadd(self, task: str, priority: str) -> str:
        with self.state._lock:
            self.state.todos.append(Todo(task, priority))
        return f"Added: {task}"

    def _tdone(self, idx: int) -> str:
        with self.state._lock:
            if 0 <= idx < len(self.state.todos):
                self.state.todos[idx].done = True
                return f"Completed #{idx}: {self.state.todos[idx].text}"
            return f"No todo at index {idx}"

    def _trem(self, idx: int) -> str:
        with self.state._lock:
            if 0 <= idx < len(self.state.todos):
                t = self.state.todos.pop(idx)
                return f"Removed: {t.text}"
            return f"No todo at index {idx}"

# ─── Agent ─────────────────────────────────────────────────────────────────────
class Agent:
    def __init__(self, state: State, executor: Executor):
        self.state    = state
        self.executor = executor
        self.conv:    List[Dict] = [{"role": "system", "content": SYSTEM_PROMPT}]
        self._stop    = False

    def stop(self):
        self._stop = True

    # ── Main loop (runs in background thread) ──────────────────────────────────
    def run(self):
        self.state.set_status("ready")
        last_cycle = 0.0

        while not self._stop:
            try:
                # Always check inbox first
                msgs = self.state.drain_inbox()
                if msgs:
                    for m in msgs:
                        self.conv.append({"role": "user", "content": m})
                    self._cycle()
                    last_cycle = time.time()

                # Autonomous tick when idle and there are pending todos
                elif time.time() - last_cycle > CYCLE_SLEEP:
                    with self.state._lock:
                        pending = [t for t in self.state.todos if not t.done]
                    if pending:
                        tasks_str = " | ".join(t.text for t in pending[:5])
                        self.conv.append({
                            "role":    "user",
                            "content": f"[system-tick] Pending todos: {tasks_str}. Continue working.",
                        })
                        self._cycle()
                    last_cycle = time.time()

                time.sleep(0.4)

            except Exception as e:
                self.state.push_log("error", f"Agent loop: {e}")
                self.state.set_status("error — retrying")
                time.sleep(3.0)

    # ── Reasoning cycle (tool-calling loop) ────────────────────────────────────
    def _cycle(self, max_turns: int = 30):
        self.state.set_status("thinking…")

        for turn in range(max_turns):
            self._trim_conv()

            # ── Call model ────────────────────────────────────────────────────
            try:
                msg = self._call_model()
            except Exception as e:
                self.state.push_log("error", f"Model call failed: {e}")
                self.state.set_status("model error")
                return

            content    = strip_think(msg.get("content") or "")
            tool_calls = msg.get("tool_calls") or []

            # Log reasoning / content
            if content:
                self.state.push_log("think", content[:800])

            # No tool calls → model is done for this cycle
            if not tool_calls:
                if content:
                    self.conv.append({"role": "assistant", "content": msg.get("content")})
                break

            # ── Append assistant turn ─────────────────────────────────────────
            self.conv.append({
                "role":       "assistant",
                "content":    msg.get("content"),
                "tool_calls": tool_calls,
            })

            # ── Execute each tool call ────────────────────────────────────────
            for tc in tool_calls:
                name = tc["function"]["name"]
                try:
                    args = json.loads(tc["function"]["arguments"])
                except Exception:
                    args = {}
                self.state.set_status(f"→ {name}")
                result = self.executor.run(name, args)
                self.conv.append({
                    "role":         "tool",
                    "tool_call_id": tc.get("id", "0"),
                    "content":      str(result)[:8000],
                })

        self.state.set_status("ready")

    # ── API call ───────────────────────────────────────────────────────────────
    def _call_model(self) -> Dict:
        r = requests.post(
            AGENT_URL,
            json={
                "messages":    self.conv,
                "tools":       TOOLS,
                "tool_choice": "auto",
                "max_tokens":  MAX_TOKENS,
                "temperature": TEMPERATURE,
            },
            timeout=180,
        )
        r.raise_for_status()
        return r.json()["choices"][0]["message"]

    # ── Trim conversation to avoid context overflow ────────────────────────────
    def _trim_conv(self):
        if len(self.conv) > CONV_TRIM + 1:
            # Keep system message + last CONV_TRIM entries
            self.conv = [self.conv[0]] + self.conv[-CONV_TRIM:]

# ─── ncurses TUI ───────────────────────────────────────────────────────────────

# Color pair IDs
_C = {
    "header": 1, "border": 2, "user": 3, "dao": 4,
    "tool": 5, "result": 6, "error": 7, "think": 8,
    "worker": 9, "system": 10, "info": 11,
    "th": 12, "tm": 13, "tl": 14, "td": 15,
    "input": 16,
}

# Prefixes and colors for log entry kinds
_LOG_STYLE = {
    "tool":   (_C["tool"],   "▶ "),
    "result": (_C["result"], "  "),
    "think":  (_C["think"],  "· "),
    "error":  (_C["error"],  "✗ "),
    "worker": (_C["worker"], "W "),
    "system": (_C["system"], "◆ "),
    "info":   (_C["info"],   "i "),
}

class TUI:
    def __init__(self, state: State):
        self.state       = state
        self.log_scroll  = 0
        self.chat_scroll = 0
        self.focus       = "chat"   # "log" | "chat" | "todo"
        self.input_buf   = ""
        self.stdscr      = None

    # ── Init ───────────────────────────────────────────────────────────────────
    def setup(self, stdscr):
        self.stdscr = stdscr
        curses.curs_set(1)
        curses.start_color()
        curses.use_default_colors()
        bg = -1

        pairs = [
            (_C["header"], curses.COLOR_CYAN,    bg),
            (_C["border"], curses.COLOR_WHITE,   bg),
            (_C["user"],   curses.COLOR_GREEN,   bg),
            (_C["dao"],    curses.COLOR_CYAN,    bg),
            (_C["tool"],   curses.COLOR_YELLOW,  bg),
            (_C["result"], curses.COLOR_WHITE,   bg),
            (_C["error"],  curses.COLOR_RED,     bg),
            (_C["think"],  curses.COLOR_BLUE,    bg),
            (_C["worker"], curses.COLOR_MAGENTA, bg),
            (_C["system"], curses.COLOR_WHITE,   bg),
            (_C["info"],   curses.COLOR_CYAN,    bg),
            (_C["th"],     curses.COLOR_RED,     bg),
            (_C["tm"],     curses.COLOR_YELLOW,  bg),
            (_C["tl"],     curses.COLOR_GREEN,   bg),
            (_C["td"],     curses.COLOR_BLACK,   bg),
            (_C["input"],  curses.COLOR_WHITE,   bg),
        ]
        for pid, fg, bk in pairs:
            curses.init_pair(pid, fg, bk)

        stdscr.timeout(50)   # getch() blocks up to 50 ms then returns ERR
        stdscr.keypad(True)

    # ── Layout ─────────────────────────────────────────────────────────────────
    def _layout(self):
        H, W    = self.stdscr.getmaxyx()
        TW      = max(20, min(30, W // 4))   # todo sidebar width
        LW      = W - TW                     # left content width
        CONTENT = max(6, H - 4)             # rows available for log + chat
        LH      = max(3, CONTENT // 2)       # log panel height
        CH      = max(3, CONTENT - LH)       # chat panel height
        return H, W, TW, LW, LH, CH

    # ── Full redraw ────────────────────────────────────────────────────────────
    def render(self):
        try:
            self.stdscr.erase()
            H, W, TW, LW, LH, CH = self._layout()
            log, chat, todos, status, wfile = self.state.snapshot()

            self._draw_header(W, status, wfile)
            self._draw_log(log,   y=1,      x=0,  h=LH,  w=LW)
            self._draw_chat(chat, y=1+LH,   x=0,  h=CH,  w=LW)
            self._draw_todo(todos, y=1,     x=LW, h=H-4, w=TW)
            self._draw_input(y=H-3, x=0, h=3, w=W)
            self.stdscr.refresh()
        except curses.error:
            pass

    # ── Header bar ─────────────────────────────────────────────────────────────
    def _draw_header(self, W: int, status: str, wfile: Optional[str]):
        wf    = f" ⟨{os.path.basename(wfile)}⟩" if wfile else ""
        left  = f" ◈ DAO{wf}"
        right = f" {status}  {datetime.now().strftime('%H:%M:%S')} "
        pad   = max(0, W - len(left) - len(right))
        line  = (left + " " * pad + right)[:W]
        try:
            self.stdscr.addstr(0, 0, line,
                               curses.color_pair(_C["header"]) | curses.A_BOLD)
        except curses.error:
            pass

    # ── Activity log panel ─────────────────────────────────────────────────────
    def _draw_log(self, log: List[LogEntry], y, x, h, w):
        foc   = (self.focus == "log")
        title = "Activity Log" + ("  ↑↓PgUp/Dn" if foc else "")
        self._box(y, x, h, w, title, foc)
        iw, ih = w - 2, h - 2
        lines  = []
        for e in log:
            cp, sym = _LOG_STYLE.get(e.kind, (_C["result"], "  "))
            prefix  = f"[{e.ts}] {sym}"
            for i, chunk in enumerate(self._wrap(e.text, max(1, iw - len(prefix)))):
                pad = prefix if i == 0 else " " * len(prefix)
                lines.append((cp, pad + chunk))
        self._scrollable(lines, y + 1, x + 1, ih, iw, self.log_scroll)

    # ── Conversation panel ─────────────────────────────────────────────────────
    def _draw_chat(self, chat: List[ChatMsg], y, x, h, w):
        foc   = (self.focus == "chat")
        title = "Conversation" + ("  ↑↓PgUp/Dn" if foc else "")
        self._box(y, x, h, w, title, foc)
        iw, ih = w - 2, h - 2
        lines  = []
        for m in chat:
            cp     = _C["user"] if m.role == "user" else _C["dao"]
            label  = "You " if m.role == "user" else "Dao "
            prefix = f"[{m.ts}] {label}: "
            bold   = curses.A_BOLD if m.role == "user" else 0
            for i, chunk in enumerate(self._wrap(m.text, max(1, iw - len(prefix)))):
                pad = prefix if i == 0 else " " * len(prefix)
                lines.append((cp, pad + chunk, bold))
        self._scrollable(lines, y + 1, x + 1, ih, iw, self.chat_scroll)

    # ── Todo sidebar ───────────────────────────────────────────────────────────
    def _draw_todo(self, todos: List[Todo], y, x, h, w):
        foc = (self.focus == "todo")
        self._box(y, x, h, w, "Plan / Todo", foc)
        iw  = w - 3
        row = y + 1
        _PRI = {"high": _C["th"], "medium": _C["tm"], "low": _C["tl"]}
        for i, t in enumerate(todos):
            if row >= y + h - 1:
                break
            cp   = _C["td"] if t.done else _PRI.get(t.priority, _C["tm"])
            mark = "✓" if t.done else ("!" if t.priority == "high" else "·")
            line = f" {mark} {t.text}"
            if len(line) > iw:
                line = line[:iw - 1] + "…"
            attr = curses.color_pair(cp)
            if t.done:
                attr |= curses.A_DIM
            elif t.priority == "high":
                attr |= curses.A_BOLD
            try:
                self.stdscr.addstr(row, x + 1, line.ljust(iw)[:iw], attr)
            except curses.error:
                pass
            row += 1

        if not todos:
            try:
                self.stdscr.addstr(y + 1, x + 2, "(no tasks)",
                                   curses.color_pair(_C["border"]) | curses.A_DIM)
            except curses.error:
                pass

    # ── Input panel ────────────────────────────────────────────────────────────
    def _draw_input(self, y, x, h, w):
        # Show command hint when user is typing a /command, otherwise show focus
        if self.input_buf.startswith("/"):
            hint = "/log  /chat  /todo  /clear  /quit  /help"
        else:
            hint = f"focus:{self.focus}  ↑↓ scroll  /cmd for commands"
        self._box(y, x, h, w, hint, focused=True)
        prompt = "> "
        avail  = max(1, w - len(prompt) - 3)
        disp   = self.input_buf[-avail:] if len(self.input_buf) > avail else self.input_buf
        try:
            self.stdscr.addstr(y + 1, x + 1, prompt,
                               curses.color_pair(_C["dao"]) | curses.A_BOLD)
            self.stdscr.addstr(y + 1, x + 1 + len(prompt), disp,
                               curses.color_pair(_C["input"]))
            self.stdscr.move(y + 1, x + 1 + len(prompt) + len(disp))
        except curses.error:
            pass

    # ── Box drawing helper ─────────────────────────────────────────────────────
    def _box(self, y: int, x: int, h: int, w: int, title: str = "", focused: bool = False):
        attr = curses.color_pair(_C["border"])
        if focused:
            attr |= curses.A_BOLD
        title = title[:max(0, w - 6)]
        pad   = max(0, w - len(title) - 5)
        top   = f"┌─ {title} {'─' * pad}┐"
        bot   = f"└{'─' * (w - 2)}┘"
        try:
            self.stdscr.addstr(y, x, top[:w], attr)
            self.stdscr.addstr(y + h - 1, x, bot[:w], attr)
            for r in range(y + 1, y + h - 1):
                self.stdscr.addstr(r, x, "│", attr)
                self.stdscr.addstr(r, x + w - 1, "│", attr)
        except curses.error:
            pass

    # ── Scroll renderer ────────────────────────────────────────────────────────
    @staticmethod
    def _wrap(text: str, width: int) -> List[str]:
        if width < 1:
            return [text[:1] or ""]
        return textwrap.wrap(text, width=width) or [""]

    def _scrollable(self, lines: List[Tuple], y: int, x: int, h: int, w: int, scroll: int):
        total  = len(lines)
        scroll = min(scroll, max(0, total - h))
        start  = max(0, total - h - scroll)
        for i, item in enumerate(lines[start : start + h]):
            if i >= h:
                break
            cp   = item[0]
            text = item[1]
            attr = curses.color_pair(cp)
            if len(item) > 2:
                attr |= item[2]    # optional bold / dim flag
            try:
                self.stdscr.addstr(y + i, x, text[:w].ljust(w)[:w], attr)
            except curses.error:
                pass

    # ── Keyboard handler ───────────────────────────────────────────────────────
    # Navigation: arrow keys scroll the focused panel.
    # Commands:   type /cmd and press Enter.
    #   /log   /chat   /todo          — switch focus
    #   /clear                        — clear input
    #   /quit  /q                     — exit
    #   /help                         — show help in log
    # Anything else: typed text → sent to Dao on Enter.

    def handle_key(self, key: int) -> bool:
        """Returns False to signal quit."""
        if key == curses.KEY_RESIZE:
            curses.resizeterm(*self.stdscr.getmaxyx())
            return True

        # ── Arrow keys: scroll focused panel ──────────────────────────────────
        if key == curses.KEY_UP:
            if self.focus == "log":    self.log_scroll  += 1
            elif self.focus == "chat": self.chat_scroll += 1
            return True
        if key == curses.KEY_DOWN:
            if self.focus == "log":    self.log_scroll  = max(0, self.log_scroll  - 1)
            elif self.focus == "chat": self.chat_scroll = max(0, self.chat_scroll - 1)
            return True
        if key == curses.KEY_PPAGE:
            if self.focus == "log":    self.log_scroll  += 8
            elif self.focus == "chat": self.chat_scroll += 8
            return True
        if key == curses.KEY_NPAGE:
            if self.focus == "log":    self.log_scroll  = max(0, self.log_scroll  - 8)
            elif self.focus == "chat": self.chat_scroll = max(0, self.chat_scroll - 8)
            return True

        # ── Backspace ──────────────────────────────────────────────────────────
        if key in (curses.KEY_BACKSPACE, 127, 8):
            self.input_buf = self.input_buf[:-1]
            return True

        # ── Enter ──────────────────────────────────────────────────────────────
        if key in (10, 13, curses.KEY_ENTER):
            raw = self.input_buf.strip()
            self.input_buf = ""
            if not raw:
                return True

            # /commands
            if raw.startswith("/"):
                return self._handle_command(raw)

            # Regular message → send to Dao
            self.state.push_chat("user", raw)
            self.state.add_inbox(raw)
            self.chat_scroll = 0   # snap to bottom
            return True

        # ── Printable character ────────────────────────────────────────────────
        if 32 <= key < 127:
            self.input_buf += chr(key)

        return True

    def _handle_command(self, raw: str) -> bool:
        """Handle /commands. Returns False to quit."""
        parts = raw[1:].lower().split()
        cmd   = parts[0] if parts else ""

        if cmd in ("q", "quit", "exit"):
            return False

        elif cmd == "log":
            self.focus = "log"
            self.state.push_log("info", "Focus → Log")

        elif cmd == "chat":
            self.focus = "chat"
            self.state.push_log("info", "Focus → Chat")

        elif cmd == "todo":
            self.focus = "todo"
            self.state.push_log("info", "Focus → Todo")

        elif cmd == "clear":
            self.input_buf = ""

        elif cmd == "help":
            self.state.push_log("info", "━━━ Commands ━━━")
            self.state.push_log("info", "/log   — focus activity log panel  (↑↓ to scroll)")
            self.state.push_log("info", "/chat  — focus conversation panel  (↑↓ to scroll)")
            self.state.push_log("info", "/todo  — focus todo panel")
            self.state.push_log("info", "/clear — clear input buffer")
            self.state.push_log("info", "/quit  — exit Dao")
            self.state.push_log("info", "Anything else: message → sent to Dao on Enter")
            self.focus = "log"

        else:
            self.state.push_log("error", f"Unknown command: /{cmd}  (try /help)")

        return True

# ─── Entry Point ───────────────────────────────────────────────────────────────
def main(stdscr):
    state    = State()
    worker   = Worker(state)
    executor = Executor(state, worker)
    agent    = Agent(state, executor)
    tui      = TUI(state)

    tui.setup(stdscr)

    state.push_log("system", "━━━ Dao Agent ━━━")
    state.push_log("system", f"Agent model:  {AGENT_URL}")
    state.push_log("system", f"Worker model: {WORKER_URL}")
    state.push_log("system", "Type a message and press Enter to talk to Dao.")
    state.push_log("system", "↑↓ arrows scroll focused panel.  /help for commands.")

    # Start agent in background thread
    t = threading.Thread(target=agent.run, daemon=True, name="dao-agent")
    t.start()

    try:
        while not state.quit:
            try:
                # getch() blocks up to timeout(50ms), returns ERR if nothing
                key = stdscr.getch()
                if key != curses.ERR:
                    if not tui.handle_key(key):
                        break
                    # Drain any additional keys that arrived during this frame
                    # (handles fast typing — don't wait, just check what's buffered)
                    stdscr.timeout(0)
                    while True:
                        k2 = stdscr.getch()
                        if k2 == curses.ERR:
                            break
                        if not tui.handle_key(k2):
                            state.quit = True
                            break
                    stdscr.timeout(50)
            except curses.error:
                pass
            tui.render()
    finally:
        agent.stop()

if __name__ == "__main__":
    try:
        curses.wrapper(main)
    except KeyboardInterrupt:
        pass
    print("Dao stopped.")
